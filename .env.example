# =============================================================================
# Assistant Juridique Malgache — Fichier de configuration d'environnement
# =============================================================================
# Copiez ce fichier en `.env` et renseignez vos valeurs réelles.
#   cp .env.example .env
#
# NE COMMITEZ JAMAIS le fichier `.env` dans votre dépôt Git.
# Ajoutez-le à .gitignore si ce n'est pas déjà fait.
# =============================================================================


# -----------------------------------------------------------------------------
# BASE DE DONNÉES PostgreSQL (OBLIGATOIRE)
# -----------------------------------------------------------------------------
# Format : postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
# Exemple local avec Docker :
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/juridique_mg


# -----------------------------------------------------------------------------
# SÉCURITÉ JWT (OBLIGATOIRE)
# -----------------------------------------------------------------------------
# Clé secrète utilisée pour signer les access tokens JWT.
# Générez une valeur forte en production :
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=changeme-remplacez-par-une-cle-aleatoire-de-64-caracteres-minimum

# Algorithme de signature (HS256 recommandé, RS256 si clé asymétrique)
JWT_ALGORITHM=HS256

# Durée de validité de l'access token en minutes (défaut : 60 = 1 heure)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Durée de validité du refresh token en jours (défaut : 30 jours)
REFRESH_TOKEN_EXPIRE_DAYS=30


# -----------------------------------------------------------------------------
# FOURNISSEUR LLM (OBLIGATOIRE)
# -----------------------------------------------------------------------------
# Valeurs acceptées :
#   mistral → Mistral AI (disponible immédiatement, recommandé pour le développement)
#   vertex  → Google Vertex AI / Gemini (recommandé pour la production)
LLM_PROVIDER=mistral


# -----------------------------------------------------------------------------
# MISTRAL AI (requis uniquement si LLM_PROVIDER=mistral)
# -----------------------------------------------------------------------------
# Récupérez votre clé sur https://console.mistral.ai/
MISTRAL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle de génération de texte (défaut : mistral-large-latest)
MISTRAL_CHAT_MODEL=mistral-large-latest

# Modèle d'embeddings pour ChromaDB (défaut : mistral-embed)
MISTRAL_EMBED_MODEL=mistral-embed


# -----------------------------------------------------------------------------
# GOOGLE CLOUD / VERTEX AI (requis uniquement si LLM_PROVIDER=vertex)
# -----------------------------------------------------------------------------
# Identifiant du projet Google Cloud (ex : assistant-juridique-mg-prod)
GCP_PROJECT_ID=

# Région Vertex AI — europe-west1 ou europe-west4 recommandées pour l'Afrique/Europe
GCP_LOCATION=europe-west1

# Modèle Gemini pour la génération de texte
# Vérifiez la disponibilité sur : https://cloud.google.com/vertex-ai/generative-ai/docs/models
GEMINI_MODEL=gemini-3-flash

# Modèle d'embedding multilingue pour ChromaDB (mg / fr / en)
GEMINI_EMBEDDING_MODEL=text-multilingual-embedding-002

# Chemin vers le fichier JSON du compte de service Google Cloud.
# En développement local : laissez vide et utilisez `gcloud auth application-default login`.
# En production (non-GKE) : chemin absolu vers le fichier de clé de service.
GOOGLE_APPLICATION_CREDENTIALS=


# -----------------------------------------------------------------------------
# CHROMADB
# -----------------------------------------------------------------------------
# Répertoire de persistance locale de la base vectorielle ChromaDB.
CHROMA_PERSIST_DIR=./chroma_data


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
# Titre affiché dans la documentation Swagger / ReDoc
APP_TITLE=Assistant Juridique Malgache — API

# Version de l'application
APP_VERSION=0.1.0

# Mode debug : active les logs SQL et la création automatique des tables au démarrage.
# Toujours False en production.
DEBUG=false
